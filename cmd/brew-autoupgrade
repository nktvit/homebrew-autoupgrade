#!/bin/bash
# brew-autoupgrade — Automatically upgrade Homebrew packages
# https://github.com/nktvit/homebrew-autoupgrade

set -euo pipefail

# ─── Constants ────────────────────────────────────────────────────────────────

VERSION="1.0.1"
PLIST_LABEL="com.brew-autoupgrade"

# Resolve Homebrew prefix (Apple Silicon vs Intel)
if [[ -d "/opt/homebrew" ]]; then
    HOMEBREW_PREFIX="/opt/homebrew"
elif [[ -d "/usr/local/Homebrew" ]]; then
    HOMEBREW_PREFIX="/usr/local"
else
    echo "Error: Homebrew installation not found." >&2
    exit 1
fi
BREW="${HOMEBREW_PREFIX}/bin/brew"

# Config paths
CONFIG_DIR="${HOME}/.config/brew-autoupgrade"
ALLOWLIST="${CONFIG_DIR}/allowlist.txt"
SCHEDULE_CONF="${CONFIG_DIR}/schedule.conf"
LAST_RUN_FILE="${CONFIG_DIR}/last-run"
LOCK_FILE="${CONFIG_DIR}/.run.lock"
SETUP_DONE="${CONFIG_DIR}/.setup-done"

# Log & plist
LOG_FILE="${HOME}/Library/Logs/brew-autoupgrade.log"
PLIST_PATH="${HOME}/Library/LaunchAgents/${PLIST_LABEL}.plist"

# Thresholds
MIN_INTERVAL_SECS=$((23 * 3600))    # 23 hours — dedup threshold
CATCHUP_SECS=$((48 * 3600))          # 48 hours — catch-up threshold
LOG_MAX_BYTES=$((5 * 1024 * 1024))   # 5 MB — log rotation threshold
PLIST_INTERVAL=14400                  # 4 hours — launchd StartInterval

# Resolve this script's absolute path, following symlinks (e.g. cmd/brew-au).
# This keeps the launchd plist pointing at the canonical script even when
# invoked via an alias.
SCRIPT_PATH="$0"
while [[ -L "$SCRIPT_PATH" ]]; do
    link_target="$(readlink "$SCRIPT_PATH")"
    if [[ "$link_target" = /* ]]; then
        SCRIPT_PATH="$link_target"
    else
        SCRIPT_PATH="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)/$link_target"
    fi
done
SCRIPT_PATH="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)/$(basename "$SCRIPT_PATH")"

# ─── Helpers ──────────────────────────────────────────────────────────────────

ensure_config_dir() {
    if [[ ! -d "$CONFIG_DIR" ]]; then
        mkdir -p -m 700 "$CONFIG_DIR"
    fi
}

log_msg() {
    local timestamp
    timestamp="$(date '+%Y-%m-%d %H:%M:%S')"
    echo "[${timestamp}] $*" >> "$LOG_FILE"
}

smart_hint() {
    local count
    count="$($BREW list 2>/dev/null | wc -l | tr -d ' ')"
    if (( count > 50 )); then
        echo ""
        echo "💡 Hint: You have ${count} packages installed. We strongly recommend"
        echo "   using the '--selected' mode to only auto-upgrade essential packages."
        echo "   This saves background processing time, preserves battery, and prevents"
        echo "   unexpected breakages in your development environment."
        echo ""
    fi
}

time_to_minutes() {
    # Convert HH:MM to minutes since midnight
    local hh mm
    hh="${1%%:*}"
    mm="${1##*:}"
    # Strip leading zeros to avoid octal interpretation
    hh=$((10#$hh))
    mm=$((10#$mm))
    echo $(( hh * 60 + mm ))
}

is_in_time_window() {
    # Returns 0 if current time is within the configured window, 1 otherwise
    if [[ ! -f "$SCHEDULE_CONF" ]]; then
        return 0  # No window configured — always in window
    fi

    local window_start window_end
    window_start="$(grep '^WINDOW_START=' "$SCHEDULE_CONF" 2>/dev/null | cut -d= -f2)" || true
    window_end="$(grep '^WINDOW_END=' "$SCHEDULE_CONF" 2>/dev/null | cut -d= -f2)" || true

    if [[ -z "$window_start" || -z "$window_end" ]]; then
        return 0  # Incomplete config — treat as no window
    fi

    local now_min start_min end_min
    now_min=$(time_to_minutes "$(date '+%H:%M')")
    start_min=$(time_to_minutes "$window_start")
    end_min=$(time_to_minutes "$window_end")

    if (( start_min <= end_min )); then
        # Normal window (e.g., 02:00 - 05:00)
        if (( now_min >= start_min && now_min < end_min )); then
            return 0
        fi
    else
        # Midnight-spanning window (e.g., 23:00 - 03:00)
        if (( now_min >= start_min || now_min < end_min )); then
            return 0
        fi
    fi

    return 1
}

get_last_run_epoch() {
    if [[ -f "$LAST_RUN_FILE" ]]; then
        cat "$LAST_RUN_FILE"
    else
        echo "0"
    fi
}

rotate_log() {
    if [[ -f "$LOG_FILE" ]]; then
        local size
        size=$(stat -f%z "$LOG_FILE" 2>/dev/null || echo 0)
        if (( size > LOG_MAX_BYTES )); then
            mv "$LOG_FILE" "${LOG_FILE}.old"
            log_msg "Log rotated (previous log exceeded 5MB)"
        fi
    fi
}

is_service_loaded() {
    launchctl list "$PLIST_LABEL" &>/dev/null
}

# ─── Setup Wizard ─────────────────────────────────────────────────────────────

cmd_setup() {
    ensure_config_dir

    echo ""
    echo "🍺 Welcome to brew-autoupgrade!"
    echo "   Let's get you set up in under a minute."
    echo ""

    # Step 1: Upgrade mode
    local pkg_count default_mode mode_choice
    pkg_count="$($BREW list 2>/dev/null | wc -l | tr -d ' ')"

    if (( pkg_count > 50 )); then
        default_mode=2
        echo "💡 You have ${pkg_count} packages installed."
        echo "   We recommend 'selected' mode for a leaner, safer experience."
        echo ""
    else
        default_mode=1
    fi

    echo "How would you like to upgrade packages?"
    echo "  [1] All packages (easy, upgrades everything)"
    echo "  [2] Selected packages only (recommended for large installations)"
    printf "Choice [%d]: " "$default_mode"
    read -r mode_choice
    mode_choice="${mode_choice:-$default_mode}"

    local upgrade_mode
    if [[ "$mode_choice" == "2" ]]; then
        upgrade_mode="selected"
    else
        upgrade_mode="all"
    fi

    # Step 2: Package selection (only for selected mode)
    if [[ "$upgrade_mode" == "selected" ]]; then
        echo ""
        echo "Let's pick packages to auto-upgrade."
        echo "You can always change this later with 'brew autoupgrade add/remove'."
        echo ""

        local selected_pkgs=""
        if command -v fzf &>/dev/null; then
            selected_pkgs="$( { $BREW list --formula 2>/dev/null; $BREW list --cask 2>/dev/null; } | sort -u | \
                fzf --multi \
                    --header="Navigate: ↑↓  Select: Tab  Confirm: Enter  Skip: Esc" \
                    --prompt="Select packages to auto-upgrade > " \
                    --preview="${BREW} info {}" \
                    --height=40% \
                    --layout=reverse 2>/dev/null || true )"
        else
            echo "fzf is not installed. It provides a much better package selection experience."
            printf "Install fzf now? [Y/n]: "
            read -r install_fzf
            install_fzf="${install_fzf:-y}"

            if [[ "$install_fzf" =~ ^[Yy] ]]; then
                echo "Installing fzf..."
                $BREW install fzf
                selected_pkgs="$( { $BREW list --formula 2>/dev/null; $BREW list --cask 2>/dev/null; } | sort -u | \
                    fzf --multi \
                        --header="Navigate: ↑↓  Select: Tab  Confirm: Enter  Skip: Esc" \
                        --prompt="Select packages to auto-upgrade > " \
                        --preview="${BREW} info {}" \
                        --height=40% \
                        --layout=reverse 2>/dev/null || true )"
            else
                # Fallback: numbered list
                echo ""
                local -a pkgs
                mapfile -t pkgs < <({ $BREW list --formula 2>/dev/null; $BREW list --cask 2>/dev/null; } | sort -u)
                local i
                for i in "${!pkgs[@]}"; do
                    printf "  %3d) %s\n" "$((i + 1))" "${pkgs[$i]}"
                done
                echo ""
                echo "Enter package numbers separated by spaces (e.g., \"1 3 5\"),"
                printf "or press Enter to skip: "
                read -r num_input
                if [[ -n "$num_input" ]]; then
                    for n in $num_input; do
                        local idx=$((n - 1))
                        if (( idx >= 0 && idx < ${#pkgs[@]} )); then
                            selected_pkgs+="${pkgs[$idx]}"$'\n'
                        fi
                    done
                fi
            fi
        fi

        # Write selected packages to allowlist
        if [[ -n "$selected_pkgs" ]]; then
            echo "$selected_pkgs" | sed '/^$/d' | sort -u > "$ALLOWLIST"
            local sel_count
            sel_count="$(wc -l < "$ALLOWLIST" | tr -d ' ')"
            echo "✓ Added ${sel_count} package(s) to your allowlist."
        else
            touch "$ALLOWLIST"
            echo "No packages selected. You can add them later with 'brew autoupgrade add <pkg>'."
        fi
    fi

    # Step 3: Schedule window
    echo ""
    echo "When should upgrades run?"
    echo "  [1] Anytime (no restriction)"
    echo "  [2] Set a time window (e.g., overnight)"
    printf "Choice [1]: "
    read -r sched_choice
    sched_choice="${sched_choice:-1}"

    if [[ "$sched_choice" == "2" ]]; then
        printf "Enter time window (HH:MM-HH:MM) [02:00-06:00]: "
        read -r window_input
        window_input="${window_input:-02:00-06:00}"
        local w_start w_end
        w_start="${window_input%%-*}"
        w_end="${window_input##*-}"
        cat > "$SCHEDULE_CONF" <<EOF
WINDOW_START=${w_start}
WINDOW_END=${w_end}
EOF
        echo "✓ Schedule window set to ${w_start} - ${w_end}."
    else
        rm -f "$SCHEDULE_CONF"
        echo "✓ No time window restriction — upgrades can run anytime."
    fi

    # Step 4: Start service
    echo ""
    echo "Start the background upgrade service now?"
    echo "  [y] Yes (recommended)"
    echo "  [n] No, I'll start it later with 'brew autoupgrade start'"
    printf "Choice [y]: "
    read -r start_choice
    start_choice="${start_choice:-y}"

    local service_status="Not running"
    if [[ "$start_choice" =~ ^[Yy] ]]; then
        cmd_start "--${upgrade_mode}"
        service_status="Running"
    fi

    # Mark setup done
    touch "$SETUP_DONE"

    # Summary
    local mode_display sel_info="" sched_display="Anytime"
    if [[ "$upgrade_mode" == "selected" ]]; then
        local ac=0
        [[ -f "$ALLOWLIST" ]] && ac="$(wc -l < "$ALLOWLIST" | tr -d ' ')"
        mode_display="Selected packages (${ac} packages)"
    else
        mode_display="All packages"
    fi

    if [[ -f "$SCHEDULE_CONF" ]]; then
        local ws we
        ws="$(grep '^WINDOW_START=' "$SCHEDULE_CONF" | cut -d= -f2)"
        we="$(grep '^WINDOW_END=' "$SCHEDULE_CONF" | cut -d= -f2)"
        sched_display="${ws} - ${we}"
    fi

    echo ""
    echo "✅ Setup complete!"
    echo "   Mode:     ${mode_display}"
    echo "   Schedule: ${sched_display}"
    echo "   Service:  ${service_status}"
    echo ""
    echo "Useful commands:"
    echo "  brew autoupgrade status    — check service status"
    echo "  brew autoupgrade add <pkg> — add a package to the allowlist"
    echo "  brew autoupgrade list      — view selected packages"
    echo "  brew autoupgrade stop      — stop the background service"
    echo ""
}

maybe_run_setup() {
    # Auto-trigger setup wizard on first run (interactive terminal only)
    if [[ ! -f "$SETUP_DONE" ]] && [[ -t 0 ]]; then
        echo "It looks like this is your first time running brew-autoupgrade."
        printf "Would you like to run the setup wizard? [Y/n]: "
        read -r run_setup
        run_setup="${run_setup:-y}"
        if [[ "$run_setup" =~ ^[Yy] ]]; then
            cmd_setup
            exit 0
        else
            ensure_config_dir
            touch "$SETUP_DONE"
        fi
    else
        ensure_config_dir
    fi
}

# ─── Subcommands ──────────────────────────────────────────────────────────────

cmd_help() {
    cat <<'USAGE'
brew autoupgrade — Automatically upgrade Homebrew packages

Usage:
  brew autoupgrade <command> [options]

Commands:
  setup                       Run the interactive setup wizard
  status                      Show service status, schedule, and allowlist info
  add <package>               Add a package to the auto-upgrade allowlist
  remove <package>            Remove a package from the allowlist
  list                        Show all packages in the allowlist
  schedule [options]          Configure upgrade time window
  run --all | --selected      Execute upgrades now
  start --all | --selected    Start the background upgrade service (launchd)
  stop                        Stop and remove the background service
  help                        Show this help message
  version                     Show version

Schedule options:
  --window HH:MM-HH:MM       Set allowed upgrade time window (e.g., 02:00-06:00)
  --clear                     Remove time window restriction

Examples:
  brew autoupgrade setup
  brew autoupgrade add node
  brew autoupgrade add google-chrome
  brew autoupgrade schedule --window 02:00-06:00
  brew autoupgrade start --selected
  brew autoupgrade run --all

Config:    ~/.config/brew-autoupgrade/
Log file:  ~/Library/Logs/brew-autoupgrade.log
USAGE
    smart_hint
}

cmd_version() {
    echo "brew-autoupgrade ${VERSION}"
}

cmd_status() {
    echo "brew-autoupgrade status"
    echo "─────────────────────────"

    # Service status
    if is_service_loaded; then
        echo "Service:    Running ✓"
        # Verify plist script path is still valid
        if [[ -f "$PLIST_PATH" ]]; then
            local plist_script
            plist_script="$(/usr/libexec/PlistBuddy -c "Print :ProgramArguments:0" "$PLIST_PATH" 2>/dev/null || true)"
            if [[ -n "$plist_script" && ! -f "$plist_script" ]]; then
                echo "⚠️  Warning: The service points to a script that no longer exists:"
                echo "            ${plist_script}"
                echo "            Run 'brew autoupgrade stop' then 'brew autoupgrade start' to fix."
            fi
        fi
    else
        echo "Service:    Not running"
    fi

    # Allowlist
    if [[ -f "$ALLOWLIST" && -s "$ALLOWLIST" ]]; then
        local count
        count="$(wc -l < "$ALLOWLIST" | tr -d ' ')"
        echo "Allowlist:  ${count} package(s)"
    else
        echo "Allowlist:  Empty"
    fi

    # Schedule
    if [[ -f "$SCHEDULE_CONF" ]]; then
        local ws we
        ws="$(grep '^WINDOW_START=' "$SCHEDULE_CONF" 2>/dev/null | cut -d= -f2)" || true
        we="$(grep '^WINDOW_END=' "$SCHEDULE_CONF" 2>/dev/null | cut -d= -f2)" || true
        if [[ -n "$ws" && -n "$we" ]]; then
            echo "Schedule:   ${ws} - ${we}"
        else
            echo "Schedule:   Anytime"
        fi
    else
        echo "Schedule:   Anytime"
    fi

    # Last run
    local last_epoch
    last_epoch="$(get_last_run_epoch)"
    if (( last_epoch > 0 )); then
        local last_human
        last_human="$(date -r "$last_epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "unknown")"
        echo "Last run:   ${last_human}"
    else
        echo "Last run:   Never"
    fi

    smart_hint
}

cmd_add() {
    local pkg="${1:-}"
    if [[ -z "$pkg" ]]; then
        echo "Usage: brew autoupgrade add <package>" >&2
        exit 1
    fi

    # Validate the package is installed
    if ! $BREW list --formula "$pkg" &>/dev/null && ! $BREW list --cask "$pkg" &>/dev/null; then
        echo "Error: '${pkg}' is not installed. Install it first with 'brew install ${pkg}'." >&2
        exit 1
    fi

    ensure_config_dir
    touch "$ALLOWLIST"

    # Check for duplicates
    if grep -qx "$pkg" "$ALLOWLIST" 2>/dev/null; then
        echo "'${pkg}' is already in the allowlist."
        return 0
    fi

    echo "$pkg" >> "$ALLOWLIST"
    echo "✓ Added '${pkg}' to the auto-upgrade allowlist."
}

cmd_remove() {
    local pkg="${1:-}"
    if [[ -z "$pkg" ]]; then
        echo "Usage: brew autoupgrade remove <package>" >&2
        exit 1
    fi

    if [[ ! -f "$ALLOWLIST" ]] || ! grep -qx "$pkg" "$ALLOWLIST" 2>/dev/null; then
        echo "Error: '${pkg}' is not in the allowlist." >&2
        exit 1
    fi

    local tmpfile
    tmpfile="$(mktemp)"
    grep -vx "$pkg" "$ALLOWLIST" > "$tmpfile"
    mv "$tmpfile" "$ALLOWLIST"
    echo "✓ Removed '${pkg}' from the auto-upgrade allowlist."
}

cmd_list() {
    if [[ ! -f "$ALLOWLIST" || ! -s "$ALLOWLIST" ]]; then
        echo "The allowlist is empty."
        echo "Add packages with: brew autoupgrade add <package>"
        return 0
    fi

    echo "Auto-upgrade allowlist:"
    while IFS= read -r pkg; do
        echo "  - ${pkg}"
    done < "$ALLOWLIST"
    echo ""
    echo "$(wc -l < "$ALLOWLIST" | tr -d ' ') package(s) total."
}

cmd_schedule() {
    ensure_config_dir

    if [[ $# -eq 0 ]]; then
        # Display current schedule
        if [[ -f "$SCHEDULE_CONF" ]]; then
            local ws we
            ws="$(grep '^WINDOW_START=' "$SCHEDULE_CONF" 2>/dev/null | cut -d= -f2)" || true
            we="$(grep '^WINDOW_END=' "$SCHEDULE_CONF" 2>/dev/null | cut -d= -f2)" || true
            if [[ -n "$ws" && -n "$we" ]]; then
                echo "Current upgrade window: ${ws} - ${we}"
                echo ""
                echo "Upgrades will only run during this window."
                echo "If the window is missed for 48+ hours, a catch-up upgrade will run."
            else
                echo "No time window configured. Upgrades can run anytime."
            fi
        else
            echo "No time window configured. Upgrades can run anytime."
        fi
        return 0
    fi

    case "$1" in
        --window)
            local window="${2:-}"
            if [[ -z "$window" ]]; then
                echo "Usage: brew autoupgrade schedule --window HH:MM-HH:MM" >&2
                exit 1
            fi

            # Validate format
            if [[ ! "$window" =~ ^[0-2][0-9]:[0-5][0-9]-[0-2][0-9]:[0-5][0-9]$ ]]; then
                echo "Error: Invalid time window format. Use HH:MM-HH:MM (e.g., 02:00-06:00)." >&2
                exit 1
            fi

            local w_start w_end
            w_start="${window%%-*}"
            w_end="${window##*-}"

            cat > "$SCHEDULE_CONF" <<EOF
WINDOW_START=${w_start}
WINDOW_END=${w_end}
EOF
            echo "✓ Upgrade window set to ${w_start} - ${w_end}."
            if [[ "$(time_to_minutes "$w_start")" -gt "$(time_to_minutes "$w_end")" ]]; then
                echo "  (This window spans midnight.)"
            fi
            ;;
        --clear)
            rm -f "$SCHEDULE_CONF"
            echo "✓ Time window restriction removed. Upgrades can run anytime."
            ;;
        *)
            echo "Usage: brew autoupgrade schedule [--window HH:MM-HH:MM | --clear]" >&2
            exit 1
            ;;
    esac
}

cmd_run() {
    local mode=""
    for arg in "$@"; do
        case "$arg" in
            --all)      mode="all" ;;
            --selected) mode="selected" ;;
        esac
    done

    if [[ -z "$mode" ]]; then
        echo "Usage: brew autoupgrade run --all | --selected" >&2
        exit 1
    fi

    ensure_config_dir

    # Step 0: Acquire exclusive lock (non-blocking, using mkdir for atomicity)
    if mkdir "$LOCK_FILE" 2>/dev/null; then
        # We got the lock — write our PID for stale lock detection
        echo $$ > "${LOCK_FILE}/pid"
        # Ensure lock is released on exit (normal, error, or signal)
        trap 'rm -rf "$LOCK_FILE"' EXIT INT TERM HUP
    else
        # Lock exists — check if the holding process is still alive
        local lock_pid
        lock_pid="$(cat "${LOCK_FILE}/pid" 2>/dev/null || echo "")"
        if [[ -n "$lock_pid" ]] && kill -0 "$lock_pid" 2>/dev/null; then
            log_msg "SKIP: Another instance is already running (PID ${lock_pid})."
            exit 0
        else
            # Stale lock — previous process died without cleanup
            log_msg "Removing stale lock (PID ${lock_pid:-unknown} is no longer running)."
            rm -rf "$LOCK_FILE"
            mkdir "$LOCK_FILE" 2>/dev/null || { log_msg "SKIP: Could not acquire lock."; exit 0; }
            echo $$ > "${LOCK_FILE}/pid"
            trap 'rm -rf "$LOCK_FILE"' EXIT INT TERM HUP
        fi
    fi

    # Step 1: Internet check
    if ! curl -sfm 5 "https://1.1.1.1" -o /dev/null 2>/dev/null; then
        log_msg "SKIP: No internet connection detected."
        exit 0
    fi

    # Step 2: Deduplication — check last run time
    local now last_epoch elapsed
    now="$(date +%s)"
    last_epoch="$(get_last_run_epoch)"
    elapsed=$(( now - last_epoch ))

    if (( last_epoch > 0 && elapsed < MIN_INTERVAL_SECS )); then
        log_msg "SKIP: Last run was $(( elapsed / 3600 ))h ago (minimum interval: 23h)."
        exit 0
    fi

    # Step 3: Time window check
    if ! is_in_time_window; then
        if (( elapsed > CATCHUP_SECS )); then
            log_msg "CATCH-UP: Outside time window but last run was $(( elapsed / 3600 ))h ago (>48h). Proceeding."
        else
            log_msg "SKIP: Outside upgrade time window. Last run $(( elapsed / 3600 ))h ago."
            exit 0
        fi
    fi

    # Step 4: Log rotation
    rotate_log

    log_msg "═══════════════════════════════════════════════════"
    log_msg "Starting upgrade run (mode: ${mode})"

    # Step 5: brew update (with timeout via background process)
    # Note: 'brew update' also git-pulls our own tap, so the on-disk script
    # below may differ from what we're running once update finishes. Bash holds
    # the original inode, so the running process completes safely on the old
    # version; the new version takes effect on the next launchd fire.
    local pre_version="$VERSION"
    log_msg "Running 'brew update'..."
    local update_pid
    "$BREW" update --quiet >> "$LOG_FILE" 2>&1 &
    update_pid=$!
    local waited=0 timed_out=0
    while kill -0 "$update_pid" 2>/dev/null; do
        sleep 5
        waited=$((waited + 5))
        if (( waited >= 300 )); then
            kill "$update_pid" 2>/dev/null
            wait "$update_pid" 2>/dev/null || true
            timed_out=1
            log_msg "WARNING: 'brew update' timed out after 5 minutes."
            break
        fi
    done
    # If we didn't time out, reap the process and capture its real exit status.
    # The `if !` form keeps `set -e` from killing the script on a non-zero exit,
    # so the "continue with stale data" fallback actually runs.
    if (( ! timed_out )); then
        if ! wait "$update_pid" 2>/dev/null; then
            log_msg "WARNING: 'brew update' failed. Continuing with stale data."
        fi
    fi

    # Self-upgrade detection — if the tap pulled a new version of this script,
    # the on-disk VERSION will differ from the one baked into the running process.
    if [[ -f "$SCRIPT_PATH" ]]; then
        local post_version
        post_version="$(grep -E '^VERSION=' "$SCRIPT_PATH" 2>/dev/null | head -1 | cut -d'"' -f2)"
        if [[ -n "$post_version" && "$post_version" != "$pre_version" ]]; then
            log_msg "Self-upgrade: ${pre_version} → ${post_version} (active on next run)."
        fi
    fi

    # Step 6: Execute upgrades
    local exit_code=0
    if [[ "$mode" == "all" ]]; then
        log_msg "Upgrading all packages..."
        if "$BREW" upgrade >> "$LOG_FILE" 2>&1; then
            log_msg "All packages upgraded successfully."
        else
            exit_code=$?
            log_msg "ERROR: 'brew upgrade' exited with code ${exit_code}."
        fi
    else
        # Selected mode
        if [[ ! -f "$ALLOWLIST" || ! -s "$ALLOWLIST" ]]; then
            log_msg "NOTICE: Allowlist is empty. Nothing to upgrade."
            echo "$now" > "$LAST_RUN_FILE"
            exit 0
        fi

        local total=0 success=0 failed=0 failed_pkgs=""
        while IFS= read -r pkg; do
            [[ -z "$pkg" ]] && continue
            total=$((total + 1))
            log_msg "Upgrading '${pkg}'..."
            if "$BREW" upgrade "$pkg" >> "$LOG_FILE" 2>&1; then
                success=$((success + 1))
            else
                failed=$((failed + 1))
                failed_pkgs+=" ${pkg}"
                log_msg "ERROR: Failed to upgrade '${pkg}'."
            fi
        done < "$ALLOWLIST"

        log_msg "Summary: ${success}/${total} succeeded, ${failed} failed."
        if [[ -n "$failed_pkgs" ]]; then
            log_msg "Failed packages:${failed_pkgs}"
            exit_code=1
        fi
    fi

    # Step 7: Update last-run timestamp
    echo "$now" > "$LAST_RUN_FILE"

    log_msg "Upgrade run complete."
    log_msg "═══════════════════════════════════════════════════"

    return $exit_code
}

cmd_start() {
    local mode=""
    for arg in "$@"; do
        case "$arg" in
            --all)      mode="all" ;;
            --selected) mode="selected" ;;
        esac
    done

    if [[ -z "$mode" ]]; then
        echo "Usage: brew autoupgrade start --all | --selected" >&2
        exit 1
    fi

    ensure_config_dir

    # Warn if selected mode with empty allowlist
    if [[ "$mode" == "selected" ]]; then
        if [[ ! -f "$ALLOWLIST" || ! -s "$ALLOWLIST" ]]; then
            echo "⚠️  Warning: The allowlist is empty. The service will run but won't upgrade anything."
            echo "   Add packages with: brew autoupgrade add <package>"
        fi
    fi

    # Stop existing service if running
    if is_service_loaded; then
        launchctl bootout "gui/$(id -u)" "$PLIST_PATH" 2>/dev/null || true
    fi

    # Generate plist
    cat > "$PLIST_PATH" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${PLIST_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${SCRIPT_PATH}</string>
        <string>run</string>
        <string>--${mode}</string>
    </array>
    <key>StartInterval</key>
    <integer>${PLIST_INTERVAL}</integer>
    <key>StandardOutPath</key>
    <string>${LOG_FILE}</string>
    <key>StandardErrorPath</key>
    <string>${LOG_FILE}</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>${HOMEBREW_PREFIX}/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
PLIST

    # Load the service
    if launchctl bootstrap "gui/$(id -u)" "$PLIST_PATH" 2>/dev/null; then
        echo "✓ Background upgrade service started (mode: ${mode})."
        echo "  The service checks every 4 hours and upgrades once daily."
        if [[ -f "$SCHEDULE_CONF" ]]; then
            local ws we
            ws="$(grep '^WINDOW_START=' "$SCHEDULE_CONF" | cut -d= -f2)"
            we="$(grep '^WINDOW_END=' "$SCHEDULE_CONF" | cut -d= -f2)"
            echo "  Upgrade window: ${ws} - ${we}"
        fi
    else
        echo "Error: Failed to load the launchd service." >&2
        echo "Try: brew autoupgrade stop && brew autoupgrade start --${mode}" >&2
        exit 1
    fi
}

cmd_stop() {
    if ! is_service_loaded && [[ ! -f "$PLIST_PATH" ]]; then
        echo "The background service is not running."
        return 0
    fi

    if is_service_loaded; then
        if launchctl bootout "gui/$(id -u)" "$PLIST_PATH" 2>/dev/null; then
            echo "✓ Background service stopped."
        else
            echo "Warning: Could not unload the service. It may have already been stopped." >&2
        fi
    fi

    if [[ -f "$PLIST_PATH" ]]; then
        rm -f "$PLIST_PATH"
        echo "✓ Service configuration removed."
    fi
}

# ─── Main Dispatcher ──────────────────────────────────────────────────────────

main() {
    local command="${1:-help}"
    shift || true

    # Auto-trigger setup for non-setup, non-run commands
    case "$command" in
        setup|run|version|--version|-v)
            ;;  # Don't auto-trigger setup for these
        *)
            maybe_run_setup
            ;;
    esac

    case "$command" in
        setup)    cmd_setup ;;
        help|--help|-h)
                  cmd_help ;;
        version|--version|-v)
                  cmd_version ;;
        status)   cmd_status ;;
        add)      cmd_add "$@" ;;
        remove)   cmd_remove "$@" ;;
        list)     cmd_list ;;
        schedule) cmd_schedule "$@" ;;
        run)      cmd_run "$@" ;;
        start)    cmd_start "$@" ;;
        stop)     cmd_stop ;;
        *)
            echo "Unknown command: ${command}" >&2
            echo "Run 'brew autoupgrade help' for usage." >&2
            exit 1
            ;;
    esac
}

main "$@"
