#!/bin/bash
# brew-autoupgrade — Automatically upgrade Homebrew packages
# https://github.com/nktvit/homebrew-autoupgrade

set -euo pipefail

# ─── Constants ────────────────────────────────────────────────────────────────

VERSION="1.0.6"
PLIST_LABEL="com.brew-autoupgrade"

# Resolve Homebrew prefix (Apple Silicon vs Intel)
if [[ -d "/opt/homebrew" ]]; then
    HOMEBREW_PREFIX="/opt/homebrew"
elif [[ -d "/usr/local/Homebrew" ]]; then
    HOMEBREW_PREFIX="/usr/local"
else
    echo "Error: Homebrew installation not found." >&2
    exit 1
fi
BREW="${HOMEBREW_PREFIX}/bin/brew"

# Config paths
CONFIG_DIR="${HOME}/.config/brew-autoupgrade"
ALLOWLIST="${CONFIG_DIR}/allowlist.txt"
SCHEDULE_CONF="${CONFIG_DIR}/schedule.conf"
LAST_RUN_FILE="${CONFIG_DIR}/last-run"
LOCK_FILE="${CONFIG_DIR}/.run.lock"
SETUP_DONE="${CONFIG_DIR}/.setup-done"
MODE_FILE="${CONFIG_DIR}/mode"        # remembers --all | --selected for run/start
LAST_CHANGES_FILE="${CONFIG_DIR}/last-changes"   # "pkg X.Y.Z -> A.B.C" lines from last run

# Log & plist
LOG_FILE="${HOME}/Library/Logs/brew-autoupgrade.log"
PLIST_PATH="${HOME}/Library/LaunchAgents/${PLIST_LABEL}.plist"

# Thresholds
MIN_INTERVAL_SECS=$((23 * 3600))    # 23 hours — dedup threshold
CATCHUP_SECS=$((48 * 3600))          # 48 hours — catch-up threshold
LOG_MAX_BYTES=$((5 * 1024 * 1024))   # 5 MB — log rotation threshold
PLIST_INTERVAL=14400                  # 4 hours — launchd StartInterval

# Resolve this script's absolute path, following symlinks (e.g. cmd/brew-au).
# This keeps the launchd plist pointing at the canonical script even when
# invoked via an alias.
SCRIPT_PATH="$0"
while [[ -L "$SCRIPT_PATH" ]]; do
    link_target="$(readlink "$SCRIPT_PATH")"
    if [[ "$link_target" = /* ]]; then
        SCRIPT_PATH="$link_target"
    else
        SCRIPT_PATH="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)/$link_target"
    fi
done
SCRIPT_PATH="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)/$(basename "$SCRIPT_PATH")"

# ─── Helpers ──────────────────────────────────────────────────────────────────

ensure_config_dir() {
    if [[ ! -d "$CONFIG_DIR" ]]; then
        mkdir -p -m 700 "$CONFIG_DIR"
    fi
}

log_msg() {
    local timestamp
    timestamp="$(date '+%Y-%m-%d %H:%M:%S')"
    echo "[${timestamp}] $*" >> "$LOG_FILE"
}

save_mode() { echo "$1" > "$MODE_FILE"; }

# Print "pkg version" lines for every installed formula + cask, sorted.
snapshot_versions() {
    {
        "$BREW" list --versions 2>/dev/null
        "$BREW" list --cask --versions 2>/dev/null
    } | sort -u
}

# Diffs two version-snapshot files and writes "pkg OLD -> NEW" lines to $1.
# A package is considered "upgraded" when it appears in both snapshots with a
# different version string. New installs and uninstalls are ignored on purpose
# — this is about upgrades, not inventory changes.
record_changes() {
    local out="$1" pre="$2" post="$3"
    : > "$out"
    join -j 1 -o 1.1,1.2,2.2 "$pre" "$post" 2>/dev/null \
        | awk '$2 != $3 { print $1, $2, "->", $3 }' \
        > "$out"
}

# Echoes the saved mode if one exists, otherwise "selected" as a sensible default.
default_mode() {
    if [[ -f "$MODE_FILE" ]]; then
        local m
        m="$(cat "$MODE_FILE" 2>/dev/null)"
        [[ "$m" == "all" || "$m" == "selected" ]] && { echo "$m"; return; }
    fi
    echo "selected"
}

# Lines in a file, or 0 if absent. Trimmed for arithmetic-safe use.
count_lines() {
    [[ -f "$1" ]] || { echo 0; return; }
    wc -l < "$1" | tr -d ' '
}

# Echoes "$start $end" if a window is configured, nothing otherwise.
read_window() {
    [[ -f "$SCHEDULE_CONF" ]] || return 0
    local ws we
    ws="$(grep '^WINDOW_START=' "$SCHEDULE_CONF" 2>/dev/null | cut -d= -f2)" || true
    we="$(grep '^WINDOW_END=' "$SCHEDULE_CONF" 2>/dev/null | cut -d= -f2)" || true
    [[ -n "$ws" && -n "$we" ]] && echo "$ws $we"
}

# Sorted list of every installed formula + cask, one per line.
installed_packages() {
    {
        "$BREW" list --formula 2>/dev/null
        "$BREW" list --cask 2>/dev/null
    } | sort -u
}

# Reads candidate package names from stdin and writes the user's picks to stdout.
# Prompts and UI go to /dev/tty so the pipe stays clean. Empty stdin → no-op.
pick_packages() {
    local header="$1" prompt="$2"
    local candidates
    candidates="$(cat)"
    [[ -z "$candidates" ]] && return 0

    if command -v fzf &>/dev/null; then
        echo "$candidates" | fzf --multi \
            --header="$header" \
            --prompt="$prompt" \
            --preview="${BREW} info {}" \
            --height=40% \
            --layout=reverse 2>/dev/null || true
        return
    fi

    {
        echo "fzf is not installed. It provides a much better selection experience."
        printf "Install fzf now? [Y/n, ↵ for yes]: "
    } > /dev/tty
    local install_fzf
    read -r install_fzf < /dev/tty
    install_fzf="${install_fzf:-y}"

    if [[ "$install_fzf" =~ ^[Yy] ]]; then
        echo "Installing fzf..." > /dev/tty
        "$BREW" install fzf > /dev/tty 2>&1
        echo "$candidates" | fzf --multi \
            --header="$header" \
            --prompt="$prompt" \
            --preview="${BREW} info {}" \
            --height=40% \
            --layout=reverse 2>/dev/null || true
        return
    fi

    # Numbered-list fallback
    local -a items=()
    local line
    while IFS= read -r line; do items+=("$line"); done <<< "$candidates"
    {
        echo ""
        local i
        for i in "${!items[@]}"; do
            printf "  %3d) %s\n" "$((i + 1))" "${items[$i]}"
        done
        echo ""
        printf "Enter numbers separated by spaces (e.g., \"1 3 5\"), or press Enter to skip: "
    } > /dev/tty
    local num_input
    read -r num_input < /dev/tty
    if [[ -n "$num_input" ]]; then
        local n idx
        for n in $num_input; do
            idx=$((n - 1))
            if (( idx >= 0 && idx < ${#items[@]} )); then
                echo "${items[$idx]}"
            fi
        done
    fi
}

smart_hint() {
    local count
    count="$($BREW list 2>/dev/null | wc -l | tr -d ' ')"
    if (( count > 50 )); then
        echo ""
        echo "💡 Hint: You have ${count} packages installed. We strongly recommend"
        echo "   using the '--selected' mode to only auto-upgrade essential packages."
        echo "   This saves background processing time, preserves battery, and prevents"
        echo "   unexpected breakages in your development environment."
        echo ""
    fi
}

time_to_minutes() {
    # Convert HH:MM to minutes since midnight
    local hh mm
    hh="${1%%:*}"
    mm="${1##*:}"
    # Strip leading zeros to avoid octal interpretation
    hh=$((10#$hh))
    mm=$((10#$mm))
    echo $(( hh * 60 + mm ))
}

is_in_time_window() {
    # Returns 0 if current time is within the configured window, 1 otherwise
    local window_start window_end
    read -r window_start window_end <<< "$(read_window)"
    if [[ -z "${window_start:-}" || -z "${window_end:-}" ]]; then
        return 0  # No window configured / incomplete — always in window
    fi

    local now_min start_min end_min
    now_min=$(time_to_minutes "$(date '+%H:%M')")
    start_min=$(time_to_minutes "$window_start")
    end_min=$(time_to_minutes "$window_end")

    if (( start_min <= end_min )); then
        # Normal window (e.g., 02:00 - 05:00)
        if (( now_min >= start_min && now_min < end_min )); then
            return 0
        fi
    else
        # Midnight-spanning window (e.g., 23:00 - 03:00)
        if (( now_min >= start_min || now_min < end_min )); then
            return 0
        fi
    fi

    return 1
}

get_last_run_epoch() {
    if [[ -f "$LAST_RUN_FILE" ]]; then
        cat "$LAST_RUN_FILE"
    else
        echo "0"
    fi
}

rotate_log() {
    if [[ -f "$LOG_FILE" ]]; then
        local size
        size=$(stat -f%z "$LOG_FILE" 2>/dev/null || echo 0)
        if (( size > LOG_MAX_BYTES )); then
            mv "$LOG_FILE" "${LOG_FILE}.old"
            log_msg "Log rotated (previous log exceeded 5MB)"
        fi
    fi
}

is_service_loaded() {
    launchctl list "$PLIST_LABEL" &>/dev/null
}

# ─── Setup Wizard ─────────────────────────────────────────────────────────────

cmd_setup() {
    ensure_config_dir

    echo ""
    echo "🍺 Welcome to brew-autoupgrade!"
    echo "   Let's get you set up in under a minute."
    echo ""

    # Step 1: Upgrade mode
    local pkg_count default_mode mode_choice
    pkg_count="$($BREW list 2>/dev/null | wc -l | tr -d ' ')"

    if (( pkg_count > 50 )); then
        default_mode=2
        echo "💡 You have ${pkg_count} packages installed."
        echo "   We recommend 'selected' mode for a leaner, safer experience."
        echo ""
    else
        default_mode=1
    fi

    echo "How would you like to upgrade packages?"
    echo "  [1] All packages (easy, upgrades everything)"
    echo "  [2] Selected packages only (recommended for large installations)"
    printf "Choice [%d, ↵ to confirm]: " "$default_mode"
    read -r mode_choice
    mode_choice="${mode_choice:-$default_mode}"

    local upgrade_mode
    if [[ "$mode_choice" == "2" ]]; then
        upgrade_mode="selected"
    else
        upgrade_mode="all"
    fi
    save_mode "$upgrade_mode"

    # Step 2: Package selection (only for selected mode)
    if [[ "$upgrade_mode" == "selected" ]]; then
        echo ""
        echo "Let's pick packages to auto-upgrade."
        echo "You can always change this later with 'brew au add/remove'."
        echo ""

        local selected_pkgs
        selected_pkgs="$(installed_packages | pick_packages \
            "Navigate: ↑↓  Select: Tab  Confirm: Enter  Skip: Esc" \
            "Select packages to auto-upgrade > ")"

        if [[ -n "$selected_pkgs" ]]; then
            echo "$selected_pkgs" | sed '/^$/d' | sort -u > "$ALLOWLIST"
            local sel_count
            sel_count="$(count_lines "$ALLOWLIST")"
            echo "✓ Added ${sel_count} package(s) to your allowlist."
        else
            touch "$ALLOWLIST"
            echo "No packages selected. You can add them later with 'brew au add'."
        fi
    fi

    # Step 3: Schedule window
    echo ""
    echo "When should upgrades run?"
    echo "  [1] Set a time window — overnight, while you're asleep (recommended)"
    echo "  [2] Any time of day — upgrades may run while you're working"
    printf "Choice [1, ↵ to confirm]: "
    read -r sched_choice
    sched_choice="${sched_choice:-1}"

    if [[ "$sched_choice" == "1" ]]; then
        printf "Enter time window (HH:MM-HH:MM) [02:00-06:00, ↵ to use default]: "
        read -r window_input
        window_input="${window_input:-02:00-06:00}"
        local w_start w_end
        w_start="${window_input%%-*}"
        w_end="${window_input##*-}"
        cat > "$SCHEDULE_CONF" <<EOF
WINDOW_START=${w_start}
WINDOW_END=${w_end}
EOF
        echo "✓ Schedule window set to ${w_start} - ${w_end}."
    else
        rm -f "$SCHEDULE_CONF"
        echo "✓ No time restriction — upgrades may run any time of day."
    fi

    # Step 4: Start service
    echo ""
    echo "Start the background upgrade service now?"
    echo "  [y] Yes (recommended)"
    echo "  [n] No, I'll start it later with 'brew au start'"
    printf "Choice [y, ↵ for yes]: "
    read -r start_choice
    start_choice="${start_choice:-y}"

    local service_status="Not running"
    if [[ "$start_choice" =~ ^[Yy] ]]; then
        cmd_start "--${upgrade_mode}"
        service_status="Running"
    fi

    # Step 5: Optional initial upgrade — gives instant feedback that it works
    # and avoids the "Last run: Never" awkwardness right after setup.
    echo ""
    echo "Run an upgrade now to confirm everything works?"
    echo "  [y] Yes — upgrade now (output streams here; may take a few minutes)"
    echo "  [n] No, wait for the scheduled run"
    printf "Choice [y, ↵ for yes]: "
    read -r run_now
    run_now="${run_now:-y}"
    local ran_initial=0
    if [[ "$run_now" =~ ^[Yy] ]]; then
        run_initial_upgrade "$upgrade_mode"
        ran_initial=1
    fi

    # Mark setup done
    touch "$SETUP_DONE"

    # Summary
    local mode_display sel_info="" sched_display="Anytime"
    if [[ "$upgrade_mode" == "selected" ]]; then
        local ac=0
        ac="$(count_lines "$ALLOWLIST")"
        mode_display="Selected packages (${ac} packages)"
    else
        mode_display="All packages"
    fi

    local ws we
    read -r ws we <<< "$(read_window)"
    if [[ -n "${ws:-}" && -n "${we:-}" ]]; then
        sched_display="${ws} - ${we}"
    fi

    echo ""
    echo "✅ Setup complete!"
    echo "   Mode:     ${mode_display}"
    echo "   Schedule: ${sched_display}"
    echo "   Service:  ${service_status}"
    if (( ran_initial )); then
        echo "   Last run: just now"
    fi
    echo ""
    echo "Useful commands (the 'au' alias works for every subcommand):"
    echo "  brew au status        — check service status"
    echo "  brew au add <pkg>     — add a package to the allowlist"
    echo "  brew au list          — view selected packages"
    echo "  brew au run --${upgrade_mode}  — upgrade now"
    echo "  brew au stop          — stop the background service"
    echo ""
}

run_initial_upgrade() {
    # A wizard-time upgrade that streams to the terminal (cmd_run is silent
    # because it's designed for launchd). Skips the lock/dedup/window machinery
    # since the user is sitting here asking for it. Still updates last-run so
    # the scheduled service won't double-fire within 23h.
    local mode="$1"
    echo ""
    echo "─── Running initial upgrade ────────────────────────"
    echo "» brew update"
    if ! "$BREW" update; then
        echo "Warning: 'brew update' had issues. Continuing anyway."
    fi

    local pre_snapshot post_snapshot
    pre_snapshot="$(mktemp)"
    post_snapshot="$(mktemp)"
    snapshot_versions > "$pre_snapshot"

    if [[ "$mode" == "all" ]]; then
        echo ""
        echo "» brew upgrade"
        "$BREW" upgrade || echo "Some packages failed to upgrade (see output above)."
    else
        if [[ ! -f "$ALLOWLIST" ]] || [[ ! -s "$ALLOWLIST" ]]; then
            echo "Allowlist is empty — nothing to upgrade."
        else
            local pkg
            while IFS= read -r pkg; do
                [[ -z "$pkg" ]] && continue
                echo ""
                echo "» brew upgrade ${pkg}"
                "$BREW" upgrade "$pkg" || echo "Warning: failed to upgrade '${pkg}'."
            done < "$ALLOWLIST"
        fi
    fi

    snapshot_versions > "$post_snapshot"
    record_changes "$LAST_CHANGES_FILE" "$pre_snapshot" "$post_snapshot"
    rm -f "$pre_snapshot" "$post_snapshot"

    date +%s > "$LAST_RUN_FILE"
    echo ""
    if [[ -s "$LAST_CHANGES_FILE" ]]; then
        local changed_n
        changed_n="$(count_lines "$LAST_CHANGES_FILE")"
        echo "Upgraded ${changed_n} package(s):"
        sed 's/^/  /' "$LAST_CHANGES_FILE"
    else
        echo "Nothing needed upgrading."
    fi
    echo "─── Initial upgrade complete ───────────────────────"
}

maybe_run_setup() {
    # Auto-trigger setup wizard on first run (interactive terminal only)
    if [[ ! -f "$SETUP_DONE" ]] && [[ -t 0 ]]; then
        echo "It looks like this is your first time running brew-autoupgrade."
        printf "Would you like to run the setup wizard? [Y/n, ↵ for yes]: "
        read -r run_setup
        run_setup="${run_setup:-y}"
        if [[ "$run_setup" =~ ^[Yy] ]]; then
            cmd_setup
            exit 0
        else
            ensure_config_dir
            touch "$SETUP_DONE"
        fi
    else
        ensure_config_dir
    fi
}

# ─── Subcommands ──────────────────────────────────────────────────────────────

cmd_help() {
    cat <<'USAGE'
brew au — Automatically upgrade Homebrew packages

Usage:
  brew au <command> [options]

Commands:
  setup                       Run the interactive setup wizard
  status                      Show service status, schedule, and allowlist info
  add [package...]            Add packages to the allowlist (interactive picker if no args)
  remove [package...]         Remove packages from the allowlist (interactive picker if no args)
  list                        Show all packages in the allowlist
  schedule [options]          Configure upgrade time window
  run [--all | --selected]    Execute upgrades now (defaults to saved mode)
  start [--all | --selected]  Start the background upgrade service (defaults to saved mode)
  stop                        Stop and remove the background service
  help                        Show this help message
  version                     Show version

Schedule options:
  --window HH:MM-HH:MM       Set allowed upgrade time window (e.g., 02:00-06:00)
  --clear                     Remove time window restriction

Examples:
  brew au setup
  brew au add node
  brew au add google-chrome
  brew au schedule --window 02:00-06:00
  brew au start --selected
  brew au run --all

Config:    ~/.config/brew-autoupgrade/
Log file:  ~/Library/Logs/brew-autoupgrade.log
USAGE
    smart_hint
}

cmd_version() {
    echo "brew-autoupgrade ${VERSION}"
}

cmd_status() {
    echo "brew-autoupgrade status"
    echo "─────────────────────────"

    # Service status
    if is_service_loaded; then
        echo "Service:    Running ✓"
        # Verify plist script path is still valid
        if [[ -f "$PLIST_PATH" ]]; then
            local plist_script
            plist_script="$(/usr/libexec/PlistBuddy -c "Print :ProgramArguments:0" "$PLIST_PATH" 2>/dev/null || true)"
            if [[ -n "$plist_script" && ! -f "$plist_script" ]]; then
                echo "⚠️  Warning: The service points to a script that no longer exists:"
                echo "            ${plist_script}"
                echo "            Run 'brew au stop' then 'brew au start' to fix."
            fi
        fi
    else
        echo "Service:    Not running"
    fi

    # Allowlist
    if [[ -f "$ALLOWLIST" && -s "$ALLOWLIST" ]]; then
        local count
        count="$(count_lines "$ALLOWLIST")"
        echo "Allowlist:  ${count} package(s)"
    else
        echo "Allowlist:  Empty"
    fi

    # Schedule
    local ws we
    read -r ws we <<< "$(read_window)"
    if [[ -n "${ws:-}" && -n "${we:-}" ]]; then
        echo "Schedule:   ${ws} - ${we}"
    else
        echo "Schedule:   Anytime"
    fi

    # Last run
    local last_epoch
    last_epoch="$(get_last_run_epoch)"
    if (( last_epoch > 0 )); then
        local last_human
        last_human="$(date -r "$last_epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "unknown")"
        echo "Last run:   ${last_human}"
    else
        echo "Last run:   Never"
    fi

    # Script last updated — mtime changes whenever `brew update` pulls a new
    # tap revision, so this is effectively "when did this tool last upgrade itself".
    if [[ -f "$SCRIPT_PATH" ]]; then
        local script_mtime
        script_mtime="$(stat -f '%Sm' -t '%Y-%m-%d %H:%M:%S' "$SCRIPT_PATH" 2>/dev/null || echo unknown)"
        echo "Updated:    ${script_mtime} (v${VERSION})"
    fi

    # Packages upgraded on the last run (snapshot diff, captured per run)
    if [[ -s "$LAST_CHANGES_FILE" ]]; then
        local changed_n
        changed_n="$(count_lines "$LAST_CHANGES_FILE")"
        echo ""
        echo "Last upgrade changed ${changed_n} package(s):"
        head -10 "$LAST_CHANGES_FILE" | sed 's/^/  /'
        if (( changed_n > 10 )); then
            echo "  ... and $((changed_n - 10)) more (see ${LAST_CHANGES_FILE})"
        fi
    fi

    smart_hint
}

cmd_add() {
    ensure_config_dir
    touch "$ALLOWLIST"

    # No args → interactive picker (TTY required)
    if [[ $# -eq 0 ]]; then
        if [[ ! -t 0 ]]; then
            echo "Usage: brew au add [package...] (or run interactively from a terminal)" >&2
            exit 1
        fi
        local candidates picks
        if [[ -s "$ALLOWLIST" ]]; then
            candidates="$(installed_packages | grep -vxFf "$ALLOWLIST" 2>/dev/null || true)"
        else
            candidates="$(installed_packages)"
        fi
        if [[ -z "$candidates" ]]; then
            echo "All your installed packages are already in the allowlist."
            return 0
        fi
        picks="$(echo "$candidates" | pick_packages \
            "Tab to select, Enter to confirm, Esc to cancel" \
            "Add packages > ")"
        if [[ -z "$picks" ]]; then
            echo "No packages selected."
            return 0
        fi
        local added=0 pkg
        while IFS= read -r pkg; do
            [[ -z "$pkg" ]] && continue
            if ! grep -qxF "$pkg" "$ALLOWLIST" 2>/dev/null; then
                echo "$pkg" >> "$ALLOWLIST"
                added=$((added + 1))
            fi
        done <<< "$picks"
        echo "✓ Added ${added} package(s) to the allowlist."
        return 0
    fi

    # 1+ args → batch add, per-package classification
    local added=0 already=0 missing=0
    local pkg seen=":"
    for pkg in "$@"; do
        [[ "$seen" == *":${pkg}:"* ]] && continue
        seen="${seen}${pkg}:"
        if ! "$BREW" list --formula "$pkg" &>/dev/null && ! "$BREW" list --cask "$pkg" &>/dev/null; then
            echo "✗ '${pkg}' is not installed (run 'brew install ${pkg}' first)."
            missing=$((missing + 1))
        elif grep -qxF "$pkg" "$ALLOWLIST" 2>/dev/null; then
            echo "- '${pkg}' is already in the allowlist."
            already=$((already + 1))
        else
            echo "$pkg" >> "$ALLOWLIST"
            echo "✓ Added '${pkg}'."
            added=$((added + 1))
        fi
    done

    local parts=()
    (( added > 0 )) && parts+=("${added} added")
    (( already > 0 )) && parts+=("${already} already present")
    (( missing > 0 )) && parts+=("${missing} not installed")
    if (( ${#parts[@]} > 0 )); then
        echo ""
        local joined
        joined="$(printf '%s, ' "${parts[@]}")"
        echo "Summary: ${joined%, }."
    fi
}

cmd_remove() {
    ensure_config_dir

    # No args → interactive picker (TTY required)
    if [[ $# -eq 0 ]]; then
        if [[ ! -t 0 ]]; then
            echo "Usage: brew au remove [package...] (or run interactively from a terminal)" >&2
            exit 1
        fi
        if [[ ! -s "$ALLOWLIST" ]]; then
            echo "The allowlist is empty — nothing to remove."
            return 0
        fi
        local picks
        picks="$(pick_packages \
            "Tab to select, Enter to remove, Esc to cancel" \
            "Remove packages > " < "$ALLOWLIST")"
        if [[ -z "$picks" ]]; then
            echo "No packages selected."
            return 0
        fi
        local picks_file tmpfile count
        picks_file="$(mktemp)"
        tmpfile="$(mktemp)"
        echo "$picks" | sed '/^$/d' > "$picks_file"
        count="$(count_lines "$picks_file")"
        grep -vxFf "$picks_file" "$ALLOWLIST" > "$tmpfile" 2>/dev/null || true
        mv "$tmpfile" "$ALLOWLIST"
        rm -f "$picks_file"
        echo "✓ Removed ${count} package(s) from the allowlist."
        return 0
    fi

    # 1+ args → batch remove
    if [[ ! -f "$ALLOWLIST" ]]; then touch "$ALLOWLIST"; fi
    local removed=0 missing=0 pkg seen=":"
    local picks_file
    picks_file="$(mktemp)"
    for pkg in "$@"; do
        [[ "$seen" == *":${pkg}:"* ]] && continue
        seen="${seen}${pkg}:"
        if grep -qxF "$pkg" "$ALLOWLIST" 2>/dev/null; then
            echo "$pkg" >> "$picks_file"
            echo "✓ Removed '${pkg}'."
            removed=$((removed + 1))
        else
            echo "✗ '${pkg}' was not in the allowlist."
            missing=$((missing + 1))
        fi
    done
    if (( removed > 0 )); then
        local tmpfile
        tmpfile="$(mktemp)"
        grep -vxFf "$picks_file" "$ALLOWLIST" > "$tmpfile" 2>/dev/null || true
        mv "$tmpfile" "$ALLOWLIST"
    fi
    rm -f "$picks_file"

    local parts=()
    (( removed > 0 )) && parts+=("${removed} removed")
    (( missing > 0 )) && parts+=("${missing} not found")
    if (( ${#parts[@]} > 0 )); then
        echo ""
        local joined
        joined="$(printf '%s, ' "${parts[@]}")"
        echo "Summary: ${joined%, }."
    fi
}

cmd_list() {
    if [[ ! -f "$ALLOWLIST" || ! -s "$ALLOWLIST" ]]; then
        echo "The allowlist is empty."
        echo "Add packages with: brew au add (interactive) or brew au add <package>..."
        return 0
    fi

    echo "Auto-upgrade allowlist:"
    while IFS= read -r pkg; do
        echo "  - ${pkg}"
    done < "$ALLOWLIST"
    echo ""
    echo "$(count_lines "$ALLOWLIST") package(s) total."
}

cmd_schedule() {
    ensure_config_dir

    if [[ $# -eq 0 ]]; then
        local ws we
        read -r ws we <<< "$(read_window)"
        if [[ -n "${ws:-}" && -n "${we:-}" ]]; then
            echo "Current upgrade window: ${ws} - ${we}"
            echo ""
            echo "Upgrades will only run during this window."
            echo "If the window is missed for 48+ hours, a catch-up upgrade will run."
        else
            echo "No time window configured. Upgrades can run anytime."
        fi
        return 0
    fi

    case "$1" in
        --window)
            local window="${2:-}"
            if [[ -z "$window" ]]; then
                echo "Usage: brew au schedule --window HH:MM-HH:MM" >&2
                exit 1
            fi

            # Validate format
            if [[ ! "$window" =~ ^[0-2][0-9]:[0-5][0-9]-[0-2][0-9]:[0-5][0-9]$ ]]; then
                echo "Error: Invalid time window format. Use HH:MM-HH:MM (e.g., 02:00-06:00)." >&2
                exit 1
            fi

            local w_start w_end
            w_start="${window%%-*}"
            w_end="${window##*-}"

            cat > "$SCHEDULE_CONF" <<EOF
WINDOW_START=${w_start}
WINDOW_END=${w_end}
EOF
            echo "✓ Upgrade window set to ${w_start} - ${w_end}."
            if [[ "$(time_to_minutes "$w_start")" -gt "$(time_to_minutes "$w_end")" ]]; then
                echo "  (This window spans midnight.)"
            fi
            ;;
        --clear)
            rm -f "$SCHEDULE_CONF"
            echo "✓ Time window restriction removed. Upgrades can run anytime."
            ;;
        *)
            echo "Usage: brew au schedule [--window HH:MM-HH:MM | --clear]" >&2
            exit 1
            ;;
    esac
}

cmd_run() {
    local mode=""
    for arg in "$@"; do
        case "$arg" in
            --all)      mode="all" ;;
            --selected) mode="selected" ;;
        esac
    done

    # No flag → use the mode set during setup/start, falling back to selected.
    if [[ -z "$mode" ]]; then
        mode="$(default_mode)"
    fi

    ensure_config_dir

    # Bootstrap the mode file for legacy installs where launchd already passes
    # an explicit --all/--selected but no MODE_FILE has ever been written.
    [[ -f "$MODE_FILE" ]] || save_mode "$mode"

    # Step 0: Acquire exclusive lock (non-blocking, using mkdir for atomicity)
    if mkdir "$LOCK_FILE" 2>/dev/null; then
        # We got the lock — write our PID for stale lock detection
        echo $$ > "${LOCK_FILE}/pid"
        # Ensure lock is released on exit (normal, error, or signal)
        trap 'rm -rf "$LOCK_FILE"' EXIT INT TERM HUP
    else
        # Lock exists — check if the holding process is still alive
        local lock_pid
        lock_pid="$(cat "${LOCK_FILE}/pid" 2>/dev/null || echo "")"
        if [[ -n "$lock_pid" ]] && kill -0 "$lock_pid" 2>/dev/null; then
            log_msg "SKIP: Another instance is already running (PID ${lock_pid})."
            exit 0
        else
            # Stale lock — previous process died without cleanup
            log_msg "Removing stale lock (PID ${lock_pid:-unknown} is no longer running)."
            rm -rf "$LOCK_FILE"
            mkdir "$LOCK_FILE" 2>/dev/null || { log_msg "SKIP: Could not acquire lock."; exit 0; }
            echo $$ > "${LOCK_FILE}/pid"
            trap 'rm -rf "$LOCK_FILE"' EXIT INT TERM HUP
        fi
    fi

    # Step 1: Internet check
    if ! curl -sfm 5 "https://1.1.1.1" -o /dev/null 2>/dev/null; then
        log_msg "SKIP: No internet connection detected."
        exit 0
    fi

    # Step 2: Deduplication — check last run time
    local now last_epoch elapsed
    now="$(date +%s)"
    last_epoch="$(get_last_run_epoch)"
    elapsed=$(( now - last_epoch ))

    if (( last_epoch > 0 && elapsed < MIN_INTERVAL_SECS )); then
        log_msg "SKIP: Last run was $(( elapsed / 3600 ))h ago (minimum interval: 23h)."
        exit 0
    fi

    # Step 3: Time window check
    if ! is_in_time_window; then
        if (( elapsed > CATCHUP_SECS )); then
            log_msg "CATCH-UP: Outside time window but last run was $(( elapsed / 3600 ))h ago (>48h). Proceeding."
        else
            log_msg "SKIP: Outside upgrade time window. Last run $(( elapsed / 3600 ))h ago."
            exit 0
        fi
    fi

    # Step 4: Log rotation
    rotate_log

    log_msg "═══════════════════════════════════════════════════"
    log_msg "Starting upgrade run (mode: ${mode})"

    # Step 5: brew update (with timeout via background process)
    # Note: 'brew update' also git-pulls our own tap, so the on-disk script
    # below may differ from what we're running once update finishes. Bash holds
    # the original inode, so the running process completes safely on the old
    # version; the new version takes effect on the next launchd fire.
    local pre_version="$VERSION"
    log_msg "Running 'brew update'..."
    local update_pid
    "$BREW" update --quiet >> "$LOG_FILE" 2>&1 &
    update_pid=$!
    local waited=0 timed_out=0
    while kill -0 "$update_pid" 2>/dev/null; do
        sleep 5
        waited=$((waited + 5))
        if (( waited >= 300 )); then
            kill "$update_pid" 2>/dev/null
            wait "$update_pid" 2>/dev/null || true
            timed_out=1
            log_msg "WARNING: 'brew update' timed out after 5 minutes."
            break
        fi
    done
    # If we didn't time out, reap the process and capture its real exit status.
    # The `if !` form keeps `set -e` from killing the script on a non-zero exit,
    # so the "continue with stale data" fallback actually runs.
    if (( ! timed_out )); then
        if ! wait "$update_pid" 2>/dev/null; then
            log_msg "WARNING: 'brew update' failed. Continuing with stale data."
        fi
    fi

    # Self-upgrade detection — if the tap pulled a new version of this script,
    # the on-disk VERSION will differ from the one baked into the running process.
    if [[ -f "$SCRIPT_PATH" ]]; then
        local post_version
        post_version="$(grep -E '^VERSION=' "$SCRIPT_PATH" 2>/dev/null | head -1 | cut -d'"' -f2)"
        if [[ -n "$post_version" && "$post_version" != "$pre_version" ]]; then
            log_msg "Self-upgrade: ${pre_version} → ${post_version} (active on next run)."
        fi
    fi

    # Step 6: Snapshot versions, run upgrades, snapshot again, record what changed.
    local pre_snapshot post_snapshot
    pre_snapshot="$(mktemp)"
    post_snapshot="$(mktemp)"
    snapshot_versions > "$pre_snapshot"

    local exit_code=0
    if [[ "$mode" == "all" ]]; then
        log_msg "Upgrading all packages..."
        if "$BREW" upgrade >> "$LOG_FILE" 2>&1; then
            log_msg "All packages upgraded successfully."
        else
            exit_code=$?
            log_msg "ERROR: 'brew upgrade' exited with code ${exit_code}."
        fi
    else
        # Selected mode
        if [[ ! -f "$ALLOWLIST" || ! -s "$ALLOWLIST" ]]; then
            log_msg "NOTICE: Allowlist is empty. Nothing to upgrade."
            rm -f "$pre_snapshot" "$post_snapshot"
            echo "$now" > "$LAST_RUN_FILE"
            exit 0
        fi

        local total=0 success=0 failed=0 failed_pkgs=""
        while IFS= read -r pkg; do
            [[ -z "$pkg" ]] && continue
            total=$((total + 1))
            log_msg "Upgrading '${pkg}'..."
            if "$BREW" upgrade "$pkg" >> "$LOG_FILE" 2>&1; then
                success=$((success + 1))
            else
                failed=$((failed + 1))
                failed_pkgs+=" ${pkg}"
                log_msg "ERROR: Failed to upgrade '${pkg}'."
            fi
        done < "$ALLOWLIST"

        log_msg "Summary: ${success}/${total} succeeded, ${failed} failed."
        if [[ -n "$failed_pkgs" ]]; then
            log_msg "Failed packages:${failed_pkgs}"
            exit_code=1
        fi
    fi

    snapshot_versions > "$post_snapshot"
    record_changes "$LAST_CHANGES_FILE" "$pre_snapshot" "$post_snapshot"
    rm -f "$pre_snapshot" "$post_snapshot"

    if [[ -s "$LAST_CHANGES_FILE" ]]; then
        local changed_n
        changed_n="$(count_lines "$LAST_CHANGES_FILE")"
        log_msg "Upgraded ${changed_n} package(s):"
        while IFS= read -r line; do log_msg "  ${line}"; done < "$LAST_CHANGES_FILE"
    else
        log_msg "No packages needed upgrading."
    fi

    # Step 7: Update last-run timestamp
    echo "$now" > "$LAST_RUN_FILE"

    log_msg "Upgrade run complete."
    log_msg "═══════════════════════════════════════════════════"

    return $exit_code
}

cmd_start() {
    local mode=""
    for arg in "$@"; do
        case "$arg" in
            --all)      mode="all" ;;
            --selected) mode="selected" ;;
        esac
    done

    # No flag → use the mode set during setup, falling back to selected.
    if [[ -z "$mode" ]]; then
        mode="$(default_mode)"
    fi

    ensure_config_dir
    save_mode "$mode"

    # Warn if selected mode with empty allowlist
    if [[ "$mode" == "selected" ]]; then
        if [[ ! -f "$ALLOWLIST" || ! -s "$ALLOWLIST" ]]; then
            echo "⚠️  Warning: The allowlist is empty. The service will run but won't upgrade anything."
            echo "   Add packages with: brew au add (interactive) or brew au add <package>..."
        fi
    fi

    # Stop existing service if running
    if is_service_loaded; then
        launchctl bootout "gui/$(id -u)" "$PLIST_PATH" 2>/dev/null || true
    fi

    # Generate plist
    cat > "$PLIST_PATH" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${PLIST_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${SCRIPT_PATH}</string>
        <string>run</string>
        <string>--${mode}</string>
    </array>
    <key>StartInterval</key>
    <integer>${PLIST_INTERVAL}</integer>
    <key>StandardOutPath</key>
    <string>${LOG_FILE}</string>
    <key>StandardErrorPath</key>
    <string>${LOG_FILE}</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>${HOMEBREW_PREFIX}/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
PLIST

    # Load the service
    if launchctl bootstrap "gui/$(id -u)" "$PLIST_PATH" 2>/dev/null; then
        echo "✓ Background upgrade service started (mode: ${mode})."
        echo "  The service checks every 4 hours and upgrades once daily."
        local ws we
        read -r ws we <<< "$(read_window)"
        if [[ -n "${ws:-}" && -n "${we:-}" ]]; then
            echo "  Upgrade window: ${ws} - ${we}"
        fi
    else
        echo "Error: Failed to load the launchd service." >&2
        echo "Try: brew au stop && brew au start --${mode}" >&2
        exit 1
    fi
}

cmd_stop() {
    if ! is_service_loaded && [[ ! -f "$PLIST_PATH" ]]; then
        echo "The background service is not running."
        return 0
    fi

    if is_service_loaded; then
        if launchctl bootout "gui/$(id -u)" "$PLIST_PATH" 2>/dev/null; then
            echo "✓ Background service stopped."
        else
            echo "Warning: Could not unload the service. It may have already been stopped." >&2
        fi
    fi

    if [[ -f "$PLIST_PATH" ]]; then
        rm -f "$PLIST_PATH"
        echo "✓ Service configuration removed."
    fi
}

# ─── Main Dispatcher ──────────────────────────────────────────────────────────

main() {
    local command="${1:-help}"
    shift || true

    # Auto-trigger setup for non-setup, non-run commands
    case "$command" in
        setup|run|version|--version|-v)
            ;;  # Don't auto-trigger setup for these
        *)
            maybe_run_setup
            ;;
    esac

    case "$command" in
        setup)    cmd_setup ;;
        help|--help|-h)
                  cmd_help ;;
        version|--version|-v)
                  cmd_version ;;
        status)   cmd_status ;;
        add)      cmd_add "$@" ;;
        remove)   cmd_remove "$@" ;;
        list)     cmd_list ;;
        schedule) cmd_schedule "$@" ;;
        run)      cmd_run "$@" ;;
        start)    cmd_start "$@" ;;
        stop)     cmd_stop ;;
        *)
            echo "Unknown command: ${command}" >&2
            echo "Run 'brew au help' for usage." >&2
            exit 1
            ;;
    esac
}

main "$@"
